{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: Configure (Debug)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset", "debug"
            ],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Debug",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "--preset", "debug",
                "--parallel"
            ],
            "dependsOn": "CMake: Configure (Debug)",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake: Configure (Release)",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--preset", "release"
            ],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "CMake: Build Release",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "--preset", "release",
                "--parallel"
            ],
            "dependsOn": "CMake: Configure (Release)",
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": "$msCompile"
        },
        {
            "label": "CMake: Clean",
            "type": "shell",
            "command": "cmake",
            "args": [
                "--build", "--preset", "debug",
                "--target", "clean"
            ],
            "group": "build",
            "presentation": { "reveal": "always", "panel": "shared" },
            "problemMatcher": []
        },
        {
            "label": "Engine: Start Editor (Debug)",
            "type": "process",
            "command": "${workspaceFolder}/build/Debug/Debug/Editor.exe",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake: Build Debug",
            "dependsOrder": "sequence",
            "group": "build",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false
            },
            "problemMatcher": []
        },
        {
            "label": "Engine: Open Project Hub",
            "type": "process",
            "command": "${workspaceFolder}/build/Debug/Debug/Editor.exe",
            "args": ["--project-hub"],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": "CMake: Build Debug",
            "dependsOrder": "sequence",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": false
            },
            "problemMatcher": []
        }
    ]
}
