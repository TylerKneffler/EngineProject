# Unit cube centred at the origin
# CCW winding viewed from outside (correct for DX12 LH pipeline:
# viewport Y-flip converts CCW-clip → CW-screen → front face with FrontCounterClockwise=FALSE)
# 8 vertices, 6 faces, 12 triangles

v -0.5 -0.5 -0.5
v  0.5 -0.5 -0.5
v  0.5  0.5 -0.5
v -0.5  0.5 -0.5
v -0.5 -0.5  0.5
v  0.5 -0.5  0.5
v  0.5  0.5  0.5
v -0.5  0.5  0.5

vn  0  0 -1
vn  0  0  1
vn -1  0  0
vn  1  0  0
vn  0 -1  0
vn  0  1  0

# Back  (-Z)  — faces camera at (0, 1.5, -3)
f 1//1 3//1 4//1
f 1//1 2//1 3//1
# Front (+Z)
f 5//2 7//2 6//2
f 5//2 8//2 7//2
# Left  (-X)
f 1//3 8//3 5//3
f 1//3 4//3 8//3
# Right (+X)
f 2//4 6//4 7//4
f 2//4 7//4 3//4
# Bottom (-Y)
f 1//5 5//5 6//5
f 1//5 6//5 2//5
# Top   (+Y)
f 4//6 7//6 8//6
f 4//6 3//6 7//6
